# ──────────────────────────────────────────────────────────────────────────
# multipurpose-discord-bot — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# ── Required: Discord application credentials ──────────────────────────────
# From https://discord.com/developers/applications → your app.
# Bot token (Bot tab → Reset Token). Keep this secret.
DISCORD_TOKEN=

# Application (client) ID (General Information tab).
CLIENT_ID=

# ── Required: bot owner ────────────────────────────────────────────────────
# Your own Discord user ID (enable Developer Mode, right-click yourself → Copy
# User ID). Gates the owner-only /add and /removeguild commands. If this is
# unset, those commands deny everyone.
OWNER_ID=

# ── Optional: command deployment helper ────────────────────────────────────
# Used only by `npm run deploy-commands` to clear leftover guild-scoped
# commands on your main/test guild. Safe to leave blank for global-only deploys.
GUILD_ID=

# ── Optional: YouTube alerts (/alerts ... provider:youtube) ────────────────
# YouTube Data API v3 key from https://console.cloud.google.com/ (enable
# "YouTube Data API v3"). Leave blank to disable YouTube alerts.
YOUTUBE_API_KEY=

# ── Optional: Twitch alerts (/alerts ... provider:twitch) ──────────────────
# App credentials from https://dev.twitch.tv/console/apps. Leave blank to
# disable Twitch alerts.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
